base_url <- "https://trading-api.kalshi.com"
# Construct the path using the ticker
endpoint_path <- paste0("/trade-api/v2/series/", series_ticker)

# 1. Generate Timestamp (ms)
options(scipen = 999)
timestamp <- sprintf("%.0f", as.numeric(Sys.time()) * 1000)

# 2. Prepare Message to Sign (Timestamp + Method + Path)
# For this endpoint, path is exactly: /trade-api/v2/series/KXHIGHNY
msg <- paste0(timestamp, "GET", endpoint_path)

# 3. Sign using OpenSSL System Call (RSA-PSS)
msg_file <- tempfile(); writeBin(charToRaw(msg), msg_file)
sig_file <- tempfile()

system2("openssl", c(
    "dgst", "-sha256",
    "-sign", private_key_path,
    "-sigopt", "rsa_padding_mode:pss",
    "-sigopt", "rsa_pss_saltlen:32",
    "-out", sig_file,
    msg_file
))

signature_b64 <- base64_encode(readBin(sig_file, "raw", n = 1024))
unlink(c(msg_file, sig_file))

# 4. Perform Request
req <- request(base_url) |>
    req_url_path(endpoint_path) |>
    req_headers(
        `KALSHI-ACCESS-KEY`       = api_key_id,
        `KALSHI-ACCESS-SIGNATURE` = signature_b64,
        `KALSHI-ACCESS-TIMESTAMP` = timestamp
    )

resp <- req_perform(req)
return(resp_body_json(resp))
